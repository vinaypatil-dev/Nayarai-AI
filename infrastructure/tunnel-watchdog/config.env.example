# ==============================================================================
# NAYARAi Tunnel Watchdog Configuration
# Target Environment: Samsung S25 (Termux)
# ==============================================================================

# Target local service port to tunnel (Next.js server)
TARGET_PORT=3001

# PM2 application name managing Tunnelmole on Samsung S25
PM2_TUNNELMOLE_APP="tunnelmole"

# Health check route on the local application (used to test vitality)
HEALTH_CHECK_PATH="/"

# Dedicated runtime state directory outside the repository
STATE_DIR="$HOME/.nayarai/tunnel-watchdog"

# File path to store the active public Tunnelmole URL
URL_STORAGE_FILE="$HOME/.nayarai/current_tunnel_url.txt"

# Log file location
LOG_FILE="$HOME/.nayarai/logs/tunnel-watchdog.log"

# Max seconds to wait for a HTTP response before considering tunnel degraded
HTTP_TIMEOUT=10

# Max seconds to wait for PM2 restart and URL extraction
RECOVERY_TIMEOUT=30

# Enable/disable extension hooks (true/false)
ENABLE_HOOKS=false

# Optional: Path to extension hooks directory
HOOKS_DIR="hooks"

